APP_NAME="AI Service"
APP_DESCRIPTION="Python AI service for Java + Python + AI learning project."
APP_VERSION="0.1.0"
MODEL_NAME="mock-chat-model"
LLM_PROVIDER="aliyun-compatible"
LLM_MODEL="qwen3.7-plus"
LLM_BASE_URL="https://your-workspace-id.cn-beijing.maas.aliyuncs.com/compatible-mode/v1"
LLM_API_KEY=""
REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
MAX_OUTPUT_TOKENS=1024
JAVA_MOCK_SERVICE_BASE_URL="http://127.0.0.1:8001"
JAVA_MOCK_SERVICE_TIMEOUT_SECONDS=5
QDRANT_BASE_URL="http://192.168.88.10:6333"
QDRANT_COLLECTION_NAME="learning_rag_chunks"
QDRANT_TIMEOUT_SECONDS=5
# Keep 8 for deterministic fake embedding smoke tests.
# For real embedding ingestion, create/use a collection whose vector size matches EMBEDDING_DIMENSION.
QDRANT_VECTOR_SIZE=8
QDRANT_API_KEY=""
EMBEDDING_PROVIDER="aliyun-compatible"
EMBEDDING_MODEL="text-embedding-v4"
EMBEDDING_BASE_URL="https://your-workspace-id.cn-beijing.maas.aliyuncs.com/compatible-mode/v1"
EMBEDDING_API_KEY=""
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=10
EMBEDDING_REQUEST_DIMENSIONS=true
TOOL_CONFIRMATION_TTL_SECONDS=300
LOG_LEVEL="INFO"
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
OPENAI_API_KEY=""
